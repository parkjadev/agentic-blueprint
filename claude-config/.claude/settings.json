{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/prune-merged-branches.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/beat-aware-prompt.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/template-guard.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-write-spelling.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-secret-scan.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-gate.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(bash .claude/hooks/*)",
      "Bash(bash claude-config/scripts/*)",
      "Bash(bash .claude/skills/*/scripts/*)"
    ],
    "deny": []
  }
}
