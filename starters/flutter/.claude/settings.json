{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter run:*)",
      "Bash(flutter clean:*)",
      "Bash(flutter gen-l10n:*)",
      "Bash(dart run build_runner:*)",
      "Bash(dart format:*)",
      "Bash(dart fix:*)",
      "Read(//**)",
      "Glob(//**)",
      "Grep(//**)"
    ],
    "ask": [
      "Bash(flutter pub get:*)",
      "Bash(flutter pub add:*)",
      "Bash(flutter pub remove:*)",
      "Bash(flutter pub upgrade:*)",
      "Bash(flutter build:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
