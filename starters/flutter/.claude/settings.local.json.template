{
  "permissions": {
    "allow": [
      // ─── Read access ───
      "cat *",
      "ls *",
      "find *",

      // ─── Flutter commands ───
      "flutter analyze",
      "flutter test *",
      "flutter run *",
      "flutter build *",
      "flutter pub get",
      "flutter pub add *",
      "flutter pub remove *",
      "flutter pub upgrade *",
      "flutter clean",
      "flutter gen-l10n",

      // ─── Dart commands ───
      "dart run build_runner *",
      "dart fix *",
      "dart format *",

      // ─── Git commands ───
      "git status *",
      "git diff *",
      "git log *",
      "git branch *",
      "git checkout *",
      "git add *",
      "git commit *",
      "git push *",
      "git pull *",
      "git fetch *",
      "git merge *",
      "git stash *",

      // ─── GitHub CLI ───
      "gh issue *",
      "gh pr *",
      "gh run *"
    ],
    "deny": []
  }
}
