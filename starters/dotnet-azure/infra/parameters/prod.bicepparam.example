// prod.bicepparam.example — copy to prod.bicepparam (gitignored) and fill
// in the placeholders. Prod should never reuse dev or staging values.
// Review the compute.bicep min/max replicas and data.bicep SKU before
// deploying to a real workload.

using '../main.bicep'

param environmentName = 'prod'
param location = 'australiaeast'
param resourceGroupName = 'rg-dotnet-azure-prod'
param baseName = 'dotazprd'

param dataProvider = 'postgres'

param entraTenantId = '<your-entra-tenant-id>'
param apiClientId = '<your-api-app-registration-client-id>'

param databaseAdminObjectId = '<entra-object-id-for-db-admin>'
param databaseAdminDisplayName = '<db-admin@your-tenant.onmicrosoft.com>'

// Replace with your ACR image reference once Phase 4 ships the Dockerfile.
param containerImage = 'mcr.microsoft.com/k8se/quickstart:latest'

param tags = {
  environment: 'prod'
  starter: 'dotnet-azure'
  managedBy: 'bicep'
  costcentre: '<your-cost-centre>'
}
