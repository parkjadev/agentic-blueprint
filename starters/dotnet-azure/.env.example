# .env.example — copy to .env and fill in the placeholders. Real values
# stay gitignored (see .gitignore). Consumed by `dotnet run` during local
# development; production values are injected by Container Apps env vars
# provisioned by infra/main.bicep.

# ─── Entra ID (JWT issuer) ────────────────────────────────────────────────
AzureAd__TenantId=<your-entra-tenant-id>
AzureAd__ClientId=<your-api-app-registration-client-id>
AzureAd__Audience=api://<your-api-app-registration-client-id>

# ─── Database (local dev) ─────────────────────────────────────────────────
# For local dev, run Postgres via `docker compose up db` (Phase 4) and
# connect with a throwaway password. Production uses managed-identity auth
# driven by the ConnectionStrings__AppDb value from compute.bicep.
ConnectionStrings__AppDb=Host=localhost;Port=5432;Database=appdb;Username=postgres;Password=dev

# ─── Azure deploy CLI (optional for `az deployment sub create`) ───────────
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_TENANT_ID=<your-entra-tenant-id>
